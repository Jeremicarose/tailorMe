{
  "name": "tailor-me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --no-lint",
    "start": "next start",
    "lint": "eslint . --quiet",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "studio": "prisma studio",
    "db:validate:postgres": "prisma validate --schema prisma/schema.postgres.prisma",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:generate:postgres:runtime": "prisma generate --schema prisma/schema.postgres.runtime.prisma",
    "db:migrate:postgres:dev": "prisma migrate dev --schema prisma/schema.postgres.prisma",
    "db:migrate:postgres:deploy": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "db:studio:postgres": "prisma studio --schema prisma/schema.postgres.prisma"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@types/mapbox-gl": "^3.4.1",
    "@types/react-big-calendar": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.6",
    "framer-motion": "^12.0.6",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.9.4",
    "next": "^15.5.18",
    "next-auth": "^4.24.11",
    "react": "^18.3.1",
    "react-big-calendar": "^1.17.1",
    "react-datepicker": "^8.1.0",
    "react-dom": "^18.3.1",
    "react-icons": "^4.12.0",
    "react-map-gl": "^7.1.9",
    "resend": "^4.1.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
