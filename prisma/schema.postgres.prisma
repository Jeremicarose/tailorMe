generator client {
  provider = "prisma-client-js"
  output   = "./generated/postgres-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            UserRole  @default(CUSTOMER)
  phoneNumber     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accounts        Account[]
  bookings        Booking[]
  sentMessages    Message[] @relation("SentMessages")
  createdReviews  Review[]  @relation("UserReviews")
  receivedReviews Review[]  @relation("ReviewedTailor")
  sessions        Session[]
  tailorProfile   Tailor?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tailor {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  specialty               String?
  bio                     String?
  location                String?
  latitude                Float?
  longitude               Float?
  address                 String?
  verificationStatus      TailorVerificationStatus @default(UNVERIFIED)
  verificationSubmittedAt DateTime?
  verificationReviewedAt  DateTime?
  verificationNotes       String?
  identityDocumentUrl     String?
  businessName            String?
  yearsOfExperience       Int?
  portfolioApproved       Boolean                  @default(false)
  availability            AvailabilityStatus?      @default(OPEN)
  maxDailyBookings        Int                      @default(5)
  bookingNoticePeriod     String                   @default("1 week")
  unavailableDates        Json?
  completionRate          Float                    @default(0.0)
  averageRating           Float                    @default(0.0)
  totalProjects           Int                      @default(0)
  onTimeDeliveries        Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  availabilities          Availability[]
  bookings                Booking[]
  projects                Project[]
  reviews                 Review[]
  services                Service[]
  user                    User                     @relation(fields: [userId], references: [id])
}

model Service {
  id          String   @id @default(cuid())
  tailorId    String
  name        String
  description String?
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tailor      Tailor   @relation(fields: [tailorId], references: [id])
}

model Availability {
  id            String             @id @default(cuid())
  tailorId      String
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  isRecurring   Boolean            @default(false)
  recurringDays String             @default("")
  status        AvailabilityStatus @default(AVAILABLE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tailor        Tailor             @relation(fields: [tailorId], references: [id])
  bookings      Booking[]
}

model Booking {
  id                       String        @id @default(cuid())
  userId                   String
  tailorId                 String
  availabilityId           String
  requestedDeliveryDate    DateTime
  actualDeliveryDate       DateTime?
  description              String?
  measurements             Json?
  startDate                DateTime?
  endDate                  DateTime?
  status                   BookingStatus @default(PENDING)
  paymentStatus            PaymentStatus @default(UNPAID)
  paymentMethod            String?
  paymentAmount            Float?
  paymentReference         String?
  paymentMerchantRequestId String?
  paymentRequestedAt       DateTime?
  paymentConfirmedAt       DateTime?
  paymentFailureReason     String?
  notes                    String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  availability             Availability  @relation(fields: [availabilityId], references: [id])
  tailor                   Tailor        @relation(fields: [tailorId], references: [id])
  user                     User          @relation(fields: [userId], references: [id])
  messages                 Message[]
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking  @relation(fields: [bookingId], references: [id])
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  tailorId   String
  userId     String
  reviewerId String
  rating     Float
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reviewer   User     @relation("UserReviews", fields: [reviewerId], references: [id])
  tailor     Tailor   @relation(fields: [tailorId], references: [id])
  user       User     @relation("ReviewedTailor", fields: [userId], references: [id])
}

model Project {
  id          String        @id @default(cuid())
  tailorId    String
  name        String
  description String?
  status      ProjectStatus @default(IN_PROGRESS)
  startDate   DateTime      @default(now())
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tailor      Tailor        @relation(fields: [tailorId], references: [id])
}

model ReminderRun {
  id                       String              @id @default(cuid())
  triggerType              ReminderTriggerType
  status                   ReminderRunStatus   @default(RUNNING)
  triggeredBy              String?
  totalBookingsScanned     Int                 @default(0)
  appointmentRemindersDue  Int                 @default(0)
  appointmentRemindersSent Int                 @default(0)
  deliveryRemindersDue     Int                 @default(0)
  deliveryRemindersSent    Int                 @default(0)
  errorMessage             String?
  startedAt                DateTime            @default(now())
  completedAt              DateTime?
}

enum UserRole {
  CUSTOMER
  TAILOR
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  READY_FOR_FITTING
  COMPLETED
  CANCELLED
  REJECTED
}

enum AvailabilityStatus {
  OPEN
  LIMITED
  CLOSED
  AVAILABLE
  BOOKED
  BLOCKED
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  INITIATED
  PAID
  FAILED
  CANCELLED
}

enum TailorVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ReminderRunStatus {
  RUNNING
  SUCCESS
  FAILED
  DRY_RUN
}

enum ReminderTriggerType {
  ADMIN
  TOKEN
}
