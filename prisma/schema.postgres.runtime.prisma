// prisma/schema.postgres.runtime.prisma
//
// Purpose:
// - Generate the default Prisma runtime client in node_modules/@prisma/client
// - Use this only for staging/production PostgreSQL runtime rehearsal
// - Keep local SQLite development untouched

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             UserRole  @default(CUSTOMER)
  phoneNumber      String?
  accounts         Account[]
  sessions         Session[]
  bookings         Booking[]
  receivedReviews  Review[]  @relation("ReviewedTailor")
  createdReviews   Review[]  @relation("UserReviews")
  sentMessages     Message[] @relation("SentMessages")
  tailorProfile    Tailor?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tailor {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  user                    User                     @relation(fields: [userId], references: [id])
  specialty               String?
  bio                     String?
  location                String?
  latitude                Float?
  longitude               Float?
  address                 String?
  verificationStatus      TailorVerificationStatus @default(UNVERIFIED)
  verificationSubmittedAt DateTime?
  verificationReviewedAt  DateTime?
  verificationNotes       String?
  identityDocumentUrl     String?
  businessName            String?
  yearsOfExperience       Int?
  portfolioApproved       Boolean                  @default(false)
  availability            AvailabilityStatus?      @default(OPEN)
  maxDailyBookings        Int                      @default(5)
  bookingNoticePeriod     String                   @default("1 week")
  unavailableDates        Json?
  completionRate          Float                    @default(0.0)
  averageRating           Float                    @default(0.0)
  totalProjects           Int                      @default(0)
  onTimeDeliveries        Int                      @default(0)
  bookings                Booking[]
  services                Service[]
  reviews                 Review[]
  projects                Project[]
  availabilities          Availability[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  tailorId    String
  tailor      Tailor   @relation(fields: [tailorId], references: [id])
  name        String
  description String?
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Availability {
  id            String             @id @default(cuid())
  tailorId      String
  tailor        Tailor             @relation(fields: [tailorId], references: [id])
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  isRecurring   Boolean            @default(false)
  recurringDays String             @default("")
  status        AvailabilityStatus @default(AVAILABLE)
  bookings      Booking[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Booking {
  id                       String        @id @default(cuid())
  userId                   String
  tailorId                 String
  availabilityId           String
  user                     User          @relation(fields: [userId], references: [id])
  tailor                   Tailor        @relation(fields: [tailorId], references: [id])
  availability             Availability  @relation(fields: [availabilityId], references: [id])
  requestedDeliveryDate    DateTime
  actualDeliveryDate       DateTime?
  description              String?
  measurements             Json?
  startDate                DateTime?
  endDate                  DateTime?
  status                   BookingStatus @default(PENDING)
  paymentStatus            PaymentStatus @default(UNPAID)
  paymentMethod            String?
  paymentAmount            Float?
  paymentReference         String?
  paymentMerchantRequestId String?
  paymentRequestedAt       DateTime?
  paymentConfirmedAt       DateTime?
  paymentFailureReason     String?
  notes                    String?
  messages                 Message[]
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  tailorId   String
  tailor     Tailor   @relation(fields: [tailorId], references: [id])
  userId     String
  user       User     @relation("ReviewedTailor", fields: [userId], references: [id])
  reviewerId String
  reviewer   User     @relation("UserReviews", fields: [reviewerId], references: [id])
  rating     Float
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  tailorId    String
  tailor      Tailor        @relation(fields: [tailorId], references: [id])
  name        String
  description String?
  status      ProjectStatus @default(IN_PROGRESS)
  startDate   DateTime      @default(now())
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum UserRole {
  CUSTOMER
  TAILOR
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  READY_FOR_FITTING
  COMPLETED
  CANCELLED
  REJECTED
}

enum AvailabilityStatus {
  OPEN
  LIMITED
  CLOSED
  AVAILABLE
  BOOKED
  BLOCKED
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  INITIATED
  PAID
  FAILED
  CANCELLED
}

enum TailorVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}
